From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Codex <codex@openai.com>
Date: Thu, 2 Apr 2026 14:00:00 +0800
Subject: [PATCH] misc: add GUI-VP PBMT test driver

Add a small misc driver that uses the GUI-VP cache-ace reserved-memory
window to validate Svpbmt mappings from Linux. The window is split into
three regions using PMA, NC, and IO mappings. A boot-time self-test makes
it easy to observe all cases without userspace.
---
 drivers/misc/Makefile          |  1 +
 drivers/misc/guivp_pbmt_test.c | 496 ++++++++++++++++++++++++++++++++++++++++
 2 files changed, 497 insertions(+)
 create mode 100644 drivers/misc/guivp_pbmt_test.c

diff --git a/drivers/misc/Makefile b/drivers/misc/Makefile
index 95c66b5ce1ef..7b3419626c4d 100644
--- a/drivers/misc/Makefile
+++ b/drivers/misc/Makefile
@@ -70,6 +70,7 @@ obj-$(CONFIG_TPS6594_PFSM)	+= tps6594-pfsm.o
 obj-$(CONFIG_NSM)		+= nsm.o
 obj-$(CONFIG_MARVELL_CN10K_DPI)	+= mrvl_cn10k_dpi.o
 lan966x-pci-objs		:= lan966x_pci.o
 lan966x-pci-objs		+= lan966x_pci.dtbo.o
 obj-$(CONFIG_MCHP_LAN966X_PCI)	+= lan966x-pci.o
+obj-y				+= guivp_pbmt_test.o
 obj-y				+= keba/
diff --git a/drivers/misc/guivp_pbmt_test.c b/drivers/misc/guivp_pbmt_test.c
new file mode 100644
index 000000000000..6cb8454024a1
--- /dev/null
+++ b/drivers/misc/guivp_pbmt_test.c
@@ -0,0 +1,496 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * GUI-VP PBMT test device
+ *
+ * The cache-ace reserved-memory window is split into three fixed regions:
+ *  - 0xE0000000-0xEFFFFFFF: PMA mapping
+ *  - 0xF0000000-0xF7FFFFFF: NC mapping
+ *  - 0xF8000000-0xFFFFFFFF: IO mapping
+ *
+ * The driver exposes /dev/guivp_pbmt_test for mmap-based validation and
+ * performs a small boot-time self-test so VP-side traces can be observed
+ * without requiring a userspace helper.
+ */
+
+#include <linux/fs.h>
+#include <linux/io.h>
+#include <linux/kernel.h>
+#include <linux/miscdevice.h>
+#include <linux/mm.h>
+#include <linux/module.h>
+#include <linux/of.h>
+#include <linux/of_reserved_mem.h>
+#include <linux/types.h>
+#include <linux/uaccess.h>
+#include <asm/asm-extable.h>
+
+#define GUIVP_PBMT_TEST_NAME "guivp_pbmt_test"
+#define GUIVP_CACHE_ACE_RMEM_PATH "/reserved-memory/cache-ace@e0000000"
+#define GUIVP_REGION_PMA_OFFSET 0x00000000ULL
+#define GUIVP_REGION_PMA_MAG_OFFSET 0x0fffc000ULL
+#define GUIVP_REGION_PMA_RSRV_NONE_OFFSET 0x0fffd000ULL
+#define GUIVP_REGION_PMA_AMO_OFFSET 0x0fffe000ULL
+#define GUIVP_REGION_PMA_FAULT_OFFSET 0x0ffff000ULL
+#define GUIVP_REGION_NC_OFFSET 0x10000000ULL
+#define GUIVP_REGION_IO_OFFSET 0x18000000ULL
+#define GUIVP_REGION_END_OFFSET 0x20000000ULL
+
+struct guivp_pbmt_test_ctx {
+	struct miscdevice miscdev;
+	phys_addr_t base;
+	phys_addr_t size;
+};
+
+static struct guivp_pbmt_test_ctx guivp_pbmt_ctx;
+
+static int guivp_pbmt_selftest_mapping(phys_addr_t phys, pgprot_t prot, const char *name);
+
+static int guivp_pbmt_lr_nofault(void __iomem *addr, u64 *old)
+{
+	long ret = 0;
+	u64 oldval = 0;
+
+	asm volatile(
+		"1: lr.d.aqrl %[old], %[mem]\n"
+		"2:\n"
+		_ASM_EXTABLE_UACCESS_ERR(1b, 2b, %[ret])
+		: [ret] "+r" (ret), [old] "=&r" (oldval),
+		  [mem] "+A" (*(u64 __force *)addr)
+		:
+		: "memory");
+
+	*old = oldval;
+	return ret;
+}
+
+static int guivp_pbmt_sc_nofault(void __iomem *addr, u64 value, u64 *status)
+{
+	long ret = 0;
+	u64 sc_status = 1;
+
+	asm volatile(
+		"1: sc.d.aqrl %[status], %[value], %[mem]\n"
+		"2:\n"
+		_ASM_EXTABLE_UACCESS_ERR(1b, 2b, %[ret])
+		: [ret] "+r" (ret), [status] "=&r" (sc_status),
+		  [mem] "+A" (*(u64 __force *)addr)
+		: [value] "r" (value)
+		: "memory");
+
+	*status = sc_status;
+	return ret;
+}
+
+static int guivp_pbmt_amo_or_nofault(void __iomem *addr, u64 op, u64 *old)
+{
+	long ret = 0;
+	u64 oldval = 0;
+
+	asm volatile(
+		"1: amoor.d.aqrl %[old], %[op], %[mem]\n"
+		"2:\n"
+		_ASM_EXTABLE_UACCESS_ERR(1b, 2b, %[ret])
+		: [ret] "+r" (ret), [old] "=&r" (oldval),
+		  [mem] "+m" (*(u64 __force *)addr)
+		: [op] "r" (op)
+		: "memory");
+
+	*old = oldval;
+	return ret;
+}
+
+static int guivp_pbmt_amo_add_nofault(void __iomem *addr, u64 op, u64 *old)
+{
+	long ret = 0;
+	u64 oldval = 0;
+
+	asm volatile(
+		"1: amoadd.d.aqrl %[old], %[op], %[mem]\n"
+		"2:\n"
+		_ASM_EXTABLE_UACCESS_ERR(1b, 2b, %[ret])
+		: [ret] "+r" (ret), [old] "=&r" (oldval),
+		  [mem] "+m" (*(u64 __force *)addr)
+		: [op] "r" (op)
+		: "memory");
+
+	*old = oldval;
+	return ret;
+}
+
+static int guivp_pbmt_amo_add_misaligned_nofault(void __iomem *addr, u64 op, u64 *old)
+{
+	long ret = 0;
+	u64 oldval = 0;
+	void *ptr = (void __force *)addr;
+
+	asm volatile(
+		"1: amoadd.d.aqrl %[old], %[op], (%[ptr])\n"
+		"2:\n"
+		_ASM_EXTABLE_UACCESS_ERR(1b, 2b, %[ret])
+		: [ret] "+r" (ret), [old] "=&r" (oldval)
+		: [op] "r" (op), [ptr] "r" (ptr)
+		: "memory");
+
+	*old = oldval;
+	return ret;
+}
+
+static const char *guivp_pbmt_region_name(loff_t offset, const struct guivp_pbmt_test_ctx *ctx)
+{
+	(void)ctx;
+
+	if (offset < GUIVP_REGION_NC_OFFSET)
+		return "PMA";
+	if (offset < GUIVP_REGION_IO_OFFSET)
+		return "NC";
+	return "IO";
+}
+
+static pgprot_t guivp_pbmt_region_pgprot(loff_t offset, pgprot_t prot, const struct guivp_pbmt_test_ctx *ctx)
+{
+	(void)ctx;
+
+	if (offset < GUIVP_REGION_NC_OFFSET)
+		return prot;
+	if (offset < GUIVP_REGION_IO_OFFSET)
+		return pgprot_writecombine(prot);
+	return pgprot_noncached(prot);
+}
+
+static loff_t guivp_pbmt_region_end(loff_t offset, const struct guivp_pbmt_test_ctx *ctx)
+{
+	if (offset < GUIVP_REGION_NC_OFFSET)
+		return GUIVP_REGION_NC_OFFSET;
+	if (offset < GUIVP_REGION_IO_OFFSET)
+		return GUIVP_REGION_IO_OFFSET;
+	return ctx->size;
+}
+
+static bool guivp_pbmt_crosses_region(loff_t offset, loff_t end, const struct guivp_pbmt_test_ctx *ctx)
+{
+	return end > guivp_pbmt_region_end(offset, ctx);
+}
+
+static int guivp_pbmt_selftest_region(const struct guivp_pbmt_test_ctx *ctx, unsigned int region,
+				      pgprot_t prot, const char *name)
+{
+	static const phys_addr_t offsets[] = {
+		GUIVP_REGION_PMA_OFFSET,
+		GUIVP_REGION_NC_OFFSET,
+		GUIVP_REGION_IO_OFFSET,
+	};
+	phys_addr_t phys = ctx->base + offsets[region];
+
+	return guivp_pbmt_selftest_mapping(phys, prot, name);
+}
+
+static pgprot_t guivp_pbmt_selftest_pgprot(unsigned int region)
+{
+	switch (region) {
+	case 0:
+		return PAGE_KERNEL;
+	case 1:
+		return pgprot_writecombine(PAGE_KERNEL);
+	default:
+		return pgprot_noncached(PAGE_KERNEL);
+	}
+}
+
+static int guivp_pbmt_selftest_mapping(phys_addr_t phys, pgprot_t prot, const char *name)
+{
+	void __iomem *addr;
+	u64 write_val;
+	u64 read_val;
+
+	write_val = phys ^ 0x5a5aa5a50f0f9696ULL;
+	read_val = 0;
+
+	addr = ioremap_prot(phys, sizeof(write_val), prot);
+	if (!addr)
+		return -ENOMEM;
+
+	memcpy_toio(addr, &write_val, sizeof(write_val));
+	memcpy_fromio(&read_val, addr, sizeof(read_val));
+
+	pr_info("%s: selftest %s phys=%pa wrote=0x%016llx read=0x%016llx\n",
+		GUIVP_PBMT_TEST_NAME, name, &phys, write_val, read_val);
+
+	iounmap(addr);
+	return 0;
+}
+
+static int guivp_pbmt_selftest_pma_fault(const struct guivp_pbmt_test_ctx *ctx)
+{
+	phys_addr_t phys = ctx->base + GUIVP_REGION_PMA_FAULT_OFFSET;
+	void __iomem *addr;
+	u64 write_val;
+	u64 read_val;
+	long read_ret;
+	long write_ret;
+
+	write_val = phys ^ 0xa5a55a5af0f06969ULL;
+	read_val = 0;
+
+	addr = ioremap_prot(phys, sizeof(write_val), PAGE_KERNEL);
+	if (!addr)
+		return -ENOMEM;
+
+	read_ret = copy_from_kernel_nofault(&read_val, (const void __force *)addr, sizeof(read_val));
+	write_ret = copy_to_kernel_nofault((void __force *)addr, &write_val, sizeof(write_val));
+	iounmap(addr);
+
+	if (!read_ret || !write_ret) {
+		pr_err("%s: fault selftest PMA_DENY phys=%pa unexpected read_ret=%ld write_ret=%ld\n",
+		       GUIVP_PBMT_TEST_NAME, &phys, read_ret, write_ret);
+		return -EIO;
+	}
+
+	pr_info("%s: fault selftest PMA_DENY phys=%pa read_ret=%ld write_ret=%ld PASS\n",
+		GUIVP_PBMT_TEST_NAME, &phys, read_ret, write_ret);
+	return 0;
+}
+
+static int guivp_pbmt_selftest_pma_amo(const struct guivp_pbmt_test_ctx *ctx)
+{
+	phys_addr_t phys = ctx->base + GUIVP_REGION_PMA_AMO_OFFSET;
+	void __iomem *addr;
+	u64 init_val;
+	u64 or_old;
+	u64 add_old;
+	long or_ret;
+	long add_ret;
+
+	init_val = phys ^ 0x13572468abcdef00ULL;
+
+	addr = ioremap_prot(phys, sizeof(init_val), PAGE_KERNEL);
+	if (!addr)
+		return -ENOMEM;
+
+	memcpy_toio(addr, &init_val, sizeof(init_val));
+	or_ret = guivp_pbmt_amo_or_nofault(addr, 0x10, &or_old);
+	add_ret = guivp_pbmt_amo_add_nofault(addr, 1, &add_old);
+	iounmap(addr);
+
+	if (or_ret || !add_ret) {
+		pr_err("%s: AMO selftest PMA_AMO_LOGICAL phys=%pa unexpected amoor_ret=%ld amoadd_ret=%ld or_old=0x%016llx add_old=0x%016llx\n",
+		       GUIVP_PBMT_TEST_NAME, &phys, or_ret, add_ret,
+		       or_old, add_old);
+		return -EIO;
+	}
+
+	pr_info("%s: AMO selftest PMA_AMO_LOGICAL phys=%pa amoor_ret=%ld amoadd_ret=%ld or_old=0x%016llx PASS\n",
+		GUIVP_PBMT_TEST_NAME, &phys, or_ret, add_ret, or_old);
+	return 0;
+}
+
+static int guivp_pbmt_selftest_pma_mag(const struct guivp_pbmt_test_ctx *ctx)
+{
+	phys_addr_t phys = ctx->base + GUIVP_REGION_PMA_MAG_OFFSET;
+	void __iomem *addr;
+	u64 init_vals[4] = {0, 0, 0, 0};
+	u64 ok_old;
+	u64 cross_old;
+	long ok_ret;
+	long cross_ret;
+
+	addr = ioremap_prot(phys, sizeof(init_vals), PAGE_KERNEL);
+	if (!addr)
+		return -ENOMEM;
+
+	memcpy_toio(addr, init_vals, sizeof(init_vals));
+	ok_ret = guivp_pbmt_amo_add_misaligned_nofault(addr + 4, 1, &ok_old);
+	cross_ret = guivp_pbmt_amo_add_misaligned_nofault(addr + 12, 1, &cross_old);
+	iounmap(addr);
+
+	if (ok_ret || !cross_ret) {
+		pr_err("%s: MAG selftest PMA_MAG16 phys=%pa unexpected ok_ret=%ld cross_ret=%ld ok_old=0x%016llx cross_old=0x%016llx\n",
+		       GUIVP_PBMT_TEST_NAME, &phys, ok_ret, cross_ret, ok_old, cross_old);
+		return -EIO;
+	}
+
+	pr_info("%s: MAG selftest PMA_MAG16 phys=%pa ok_ret=%ld cross_ret=%ld PASS\n",
+		GUIVP_PBMT_TEST_NAME, &phys, ok_ret, cross_ret);
+	return 0;
+}
+
+static int guivp_pbmt_selftest_pma_reservability(const struct guivp_pbmt_test_ctx *ctx)
+{
+	phys_addr_t phys = ctx->base + GUIVP_REGION_PMA_RSRV_NONE_OFFSET;
+	void __iomem *addr;
+	u64 init_val;
+	u64 lr_old;
+	u64 sc_status;
+	long lr_ret;
+	long sc_ret;
+
+	init_val = phys ^ 0x24681357fedcba00ULL;
+
+	addr = ioremap_prot(phys, sizeof(init_val), PAGE_KERNEL);
+	if (!addr)
+		return -ENOMEM;
+
+	memcpy_toio(addr, &init_val, sizeof(init_val));
+	lr_ret = guivp_pbmt_lr_nofault(addr, &lr_old);
+	sc_ret = guivp_pbmt_sc_nofault(addr, init_val + 1, &sc_status);
+	iounmap(addr);
+
+	if (!lr_ret || !sc_ret) {
+		pr_err("%s: reservability selftest PMA_RSRV_NONE phys=%pa unexpected lr_ret=%ld sc_ret=%ld sc_status=%llu\n",
+		       GUIVP_PBMT_TEST_NAME, &phys, lr_ret, sc_ret, sc_status);
+		return -EIO;
+	}
+
+	pr_info("%s: reservability selftest PMA_RSRV_NONE phys=%pa lr_ret=%ld sc_ret=%ld PASS\n",
+		GUIVP_PBMT_TEST_NAME, &phys, lr_ret, sc_ret);
+	return 0;
+}
+
+static int guivp_pbmt_run_selftest(const struct guivp_pbmt_test_ctx *ctx)
+{
+	int ret;
+	static const char * const names[] = {"PMA", "NC", "IO"};
+	unsigned int i;
+
+	for (i = 0; i < ARRAY_SIZE(names); i++) {
+		ret = guivp_pbmt_selftest_region(ctx, i, guivp_pbmt_selftest_pgprot(i), names[i]);
+		if (ret)
+			return ret;
+	}
+
+	ret = guivp_pbmt_selftest_pma_fault(ctx);
+	if (ret)
+		return ret;
+
+	ret = guivp_pbmt_selftest_pma_amo(ctx);
+	if (ret)
+		return ret;
+
+	ret = guivp_pbmt_selftest_pma_mag(ctx);
+	if (ret)
+		return ret;
+
+	ret = guivp_pbmt_selftest_pma_reservability(ctx);
+	if (ret)
+		return ret;
+
+	return 0;
+}
+
+static int guivp_pbmt_open(struct inode *inode, struct file *file)
+{
+	file->private_data = &guivp_pbmt_ctx;
+	return 0;
+}
+
+static int guivp_pbmt_mmap(struct file *file, struct vm_area_struct *vma)
+{
+	struct guivp_pbmt_test_ctx *ctx = file->private_data;
+	const unsigned long size = vma->vm_end - vma->vm_start;
+	const loff_t offset = (loff_t)vma->vm_pgoff << PAGE_SHIFT;
+	const loff_t end = offset + size;
+	const phys_addr_t phys = ctx->base + offset;
+	pgprot_t prot;
+
+	if (!ctx || !size)
+		return -EINVAL;
+
+	if (offset < 0 || end > ctx->size)
+		return -EINVAL;
+
+	if (guivp_pbmt_crosses_region(offset, end, ctx))
+		return -EINVAL;
+
+	prot = guivp_pbmt_region_pgprot(offset, vma->vm_page_prot, ctx);
+	vma->vm_page_prot = prot;
+	vm_flags_set(vma, VM_IO | VM_PFNMAP | VM_DONTEXPAND | VM_DONTDUMP);
+
+	pr_info("%s: mmap region=%s phys=0x%llx size=0x%lx pgoff=0x%llx\n",
+		GUIVP_PBMT_TEST_NAME, guivp_pbmt_region_name(offset, ctx),
+		(unsigned long long)phys, size, (unsigned long long)offset);
+
+	return remap_pfn_range(vma, vma->vm_start, phys >> PAGE_SHIFT, size, prot);
+}
+
+static const struct file_operations guivp_pbmt_fops = {
+	.owner = THIS_MODULE,
+	.open = guivp_pbmt_open,
+	.mmap = guivp_pbmt_mmap,
+	.llseek = noop_llseek,
+};
+
+static int __init guivp_pbmt_init(void)
+{
+	struct device_node *np;
+	struct reserved_mem *rmem;
+	int ret;
+
+	np = of_find_node_by_path(GUIVP_CACHE_ACE_RMEM_PATH);
+	if (!np) {
+		pr_info("%s: reserved-memory node %s not found, skipping\n",
+			GUIVP_PBMT_TEST_NAME, GUIVP_CACHE_ACE_RMEM_PATH);
+		return 0;
+	}
+
+	rmem = of_reserved_mem_lookup(np);
+	of_node_put(np);
+	if (!rmem) {
+		pr_info("%s: reserved-memory lookup failed, skipping\n", GUIVP_PBMT_TEST_NAME);
+		return 0;
+	}
+
+	if (rmem->size < GUIVP_REGION_END_OFFSET) {
+		pr_err("%s: reserved-memory window too small: %pa bytes\n",
+		       GUIVP_PBMT_TEST_NAME, &rmem->size);
+		return -EINVAL;
+	}
+
+	guivp_pbmt_ctx.base = rmem->base;
+	guivp_pbmt_ctx.size = rmem->size;
+
+	guivp_pbmt_ctx.miscdev.minor = MISC_DYNAMIC_MINOR;
+	guivp_pbmt_ctx.miscdev.name = GUIVP_PBMT_TEST_NAME;
+	guivp_pbmt_ctx.miscdev.fops = &guivp_pbmt_fops;
+	guivp_pbmt_ctx.miscdev.mode = 0600;
+
+	pr_info("%s: reserved window base=%pa size=%pa PMA=%#llx-%#llx PMA_MAG16=%#llx-%#llx PMA_RSRV_NONE=%#llx-%#llx PMA_AMO_LOGICAL=%#llx-%#llx PMA_DENY=%#llx-%#llx NC=%#llx-%#llx IO=%#llx-%#llx\n",
+		GUIVP_PBMT_TEST_NAME,
+		&guivp_pbmt_ctx.base,
+		&guivp_pbmt_ctx.size,
+		(unsigned long long)GUIVP_REGION_PMA_OFFSET,
+		(unsigned long long)(GUIVP_REGION_PMA_MAG_OFFSET - 1),
+		(unsigned long long)GUIVP_REGION_PMA_MAG_OFFSET,
+		(unsigned long long)(GUIVP_REGION_PMA_RSRV_NONE_OFFSET - 1),
+		(unsigned long long)GUIVP_REGION_PMA_RSRV_NONE_OFFSET,
+		(unsigned long long)(GUIVP_REGION_PMA_AMO_OFFSET - 1),
+		(unsigned long long)GUIVP_REGION_PMA_AMO_OFFSET,
+		(unsigned long long)(GUIVP_REGION_PMA_FAULT_OFFSET - 1),
+		(unsigned long long)GUIVP_REGION_PMA_FAULT_OFFSET,
+		(unsigned long long)(GUIVP_REGION_NC_OFFSET - 1),
+		(unsigned long long)GUIVP_REGION_NC_OFFSET,
+		(unsigned long long)(GUIVP_REGION_IO_OFFSET - 1),
+		(unsigned long long)GUIVP_REGION_IO_OFFSET,
+		(unsigned long long)(GUIVP_REGION_END_OFFSET - 1));
+
+	ret = misc_register(&guivp_pbmt_ctx.miscdev);
+	if (ret) {
+		pr_err("%s: misc_register failed: %d\n", GUIVP_PBMT_TEST_NAME, ret);
+		return ret;
+	}
+
+	ret = guivp_pbmt_run_selftest(&guivp_pbmt_ctx);
+	if (ret)
+		pr_err("%s: selftest failed: %d\n", GUIVP_PBMT_TEST_NAME, ret);
+
+	return 0;
+}
+
+static void __exit guivp_pbmt_exit(void)
+{
+	misc_deregister(&guivp_pbmt_ctx.miscdev);
+}
+
+module_init(guivp_pbmt_init);
+module_exit(guivp_pbmt_exit);
+
+MODULE_DESCRIPTION("GUI-VP PBMT test misc device");
+MODULE_LICENSE("GPL");
--
2.43.0
